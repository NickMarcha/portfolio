---
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import GitHubButton from '../../../components/GitHubButton.astro';
import ThemeToggle from '../../../components/ThemeToggle.astro';
import LanguageButton from '../../../components/LanguageButton.astro';
import ShareButton from '../../../components/ShareButton.astro';
import ProjectDetail from '../../../components/ProjectDetail.astro';
import { GlobalSearch, SearchCommandTrigger } from '../../../components/SearchCommand';
import { projectData } from '../../../data/projectData';
import { getProjectContent, t, withLang } from '../../../i18n';

export function getStaticPaths() {
	return projectData.map((project) => ({
		params: { slug: project.slug },
		props: { project, slug: project.slug },
	}));
}

const { project, slug } = Astro.props;
const lang = 'es';
const content = getProjectContent(slug, lang);
const siteTitle = t('siteTitle', lang);
const pageTitle = `${content?.longTitle ?? slug} | ${siteTitle}`;
const pageDescription = content?.shortDescription ?? '';
const carouselItemsWithCaptions = project.long.carouselItems.map((item, i) => ({
	...item,
	caption: content?.carouselCaptions?.[String(i)],
}));
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead title={pageTitle} description={pageDescription} lang={lang} />
	</head>
	<body>
		<main>
			<div class="back-row">
				<a href={withLang('/', lang)} class="back-link">{t('backToProjects', lang)}</a>
				<SearchCommandTrigger lang={lang} client:load />
			</div>
			<ProjectDetail
				project={project}
				slug={slug}
				lang={lang}
				longTitle={content?.longTitle ?? slug}
				carouselItems={carouselItemsWithCaptions}
				body={content?.body}
			/>
		</main>
		<Footer />
		<GlobalSearch lang={lang} client:load />
		<ShareButton pathname={`/es/projects/${slug}`} lang={lang} />
		<LanguageButton />
		<GitHubButton lang={lang} />
		<ThemeToggle lang={lang} />
	</body>
</html>

<style>
	.back-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 1.5em;
	}
	.back-link {
		text-decoration: none;
		color: var(--primary);
	}
	.back-link:hover {
		text-decoration: underline;
	}
</style>
