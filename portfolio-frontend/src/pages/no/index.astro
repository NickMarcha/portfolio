---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import GitHubButton from '../../components/GitHubButton.astro';
import ThemeToggle from '../../components/ThemeToggle.astro';
import LanguageButton from '../../components/LanguageButton.astro';
import ShareButton from '../../components/ShareButton.astro';
import { GlobalSearch, SearchCommandTrigger } from '../../components/SearchCommand';
import ProjectCard from '../../components/ProjectCard.astro';
import { projectData } from '../../data/projectData';
import { getProjectContent, t, withLang } from '../../i18n';
import KriskogramImage from '../../assets/Kriskogram.png';
import WatermarkBackground from '../../components/WatermarkBackground.astro';

const lang = 'no';
const siteTitle = t('siteTitle', lang);
const siteDescription = t('siteDescription', lang);
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead title={siteTitle} description={siteDescription} lang={lang} />
	</head>
	<body>
		<WatermarkBackground />
		<main>
			<div class="title-row">
				<div class="home-block home-block-title">
					<h1>{t('projects', lang)}</h1>
				</div>
				<SearchCommandTrigger lang={lang} client:load />
			</div>
			<div class="home-block home-block-intro">
				<p class="intro">{siteDescription}</p>
			</div>
			<div class="projects-grid">
				{projectData.map((project) => {
					const content = getProjectContent(project.slug, lang);
					return (
						<ProjectCard
							title={content?.shortTitle ?? project.slug}
							description={content?.shortDescription ?? ''}
							image={project.slug === 'kriskogram' ? KriskogramImage.src : project.short.image}
							href={withLang(`/projects/${project.slug}`, lang)}
							slug={project.slug}
							pixelArt={project.slug === 'bio'}
							useIcon={project.slug === 'school-assignments'}
							tags={project.tags}
							lang={lang}
						/>
					);
				})}
			</div>
		</main>
		<Footer />
		<GlobalSearch lang={lang} client:load />
		<ShareButton pathname="/no/" lang={lang} />
		<LanguageButton />
		<GitHubButton lang={lang} />
		<ThemeToggle lang={lang} />
	</body>
</html>

<style>
	.title-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		margin: 0 0 1em 0;
	}
	.title-row h1 {
		margin: 0;
	}
	.intro {
		margin: 0;
		color: var(--text-muted);
	}
	.projects-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 1.5em;
	}
</style>
