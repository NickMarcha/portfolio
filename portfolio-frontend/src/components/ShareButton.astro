---
import { t, getLangFromUrl } from '../i18n';

interface Props {
	pathname?: string;
	lang?: string;
}
const { pathname = Astro.url.pathname, lang = getLangFromUrl(Astro.url) } = Astro.props;

const site = Astro.site?.toString() ?? 'https://portfolio.nickmarcha.com';
const fullUrl = `${site}${pathname}${Astro.url.search || ''}`;

// QR path: home-en, projects-bio-no, etc. (path-based locales)
const segments = pathname.replace(/^\//, '').split('/').filter(Boolean);
const isHome = segments.length === 0 || (segments.length === 1 && ['no', 'es'].includes(segments[0]));
const slug = pathname.includes('/projects/') ? segments[segments.length - 1] : null;
const qrPath = isHome
	? `/qr/home-${lang}.svg`
	: slug
		? `/qr/projects-${slug}-${lang}.svg`
		: null;
---
<div id="share-button" class="share-button">
	<button type="button" class="share-btn" aria-haspopup="menu" aria-expanded="false" aria-label={t('share', lang)}>
		<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
			<circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" x2="15.42" y1="13.51" y2="17.49"/><line x1="15.41" x2="8.59" y1="6.51" y2="10.49"/>
		</svg>
		<span class="share-label">{t('share', lang)}</span>
	</button>
	<div class="share-menu" role="menu">
		<button type="button" class="share-option" data-action="share">
			{t('share', lang)}
		</button>
		<button type="button" class="share-option" data-action="copy">
			{t('copyLink', lang)}
		</button>
		{qrPath && (
			<button type="button" class="share-option" data-action="qr">
				{t('showQR', lang)}
			</button>
		)}
	</div>
</div>
{qrPath && (
	<div id="share-qr-overlay" class="share-qr-overlay" hidden role="dialog" aria-modal="true" aria-label="QR code">
		<div class="share-qr-backdrop"></div>
		<div class="share-qr-content">
			<button type="button" class="share-qr-close" aria-label="Close">×</button>
			<img src={qrPath} alt="QR code" />
		</div>
	</div>
)}

<script define:vars={{ fullUrl }}>
	document.addEventListener('DOMContentLoaded', () => {
		const container = document.getElementById('share-button');
		const btn = container?.querySelector('.share-btn');
		const menu = container?.querySelector('.share-menu');
		const qrOverlay = document.getElementById('share-qr-overlay');
		const options = container?.querySelectorAll('.share-option');

		if (!container || !btn || !menu) return;

		function closeQrOverlay() {
			if (qrOverlay) qrOverlay.hidden = true;
		}

		btn.addEventListener('click', (e) => {
			e.stopPropagation();
			const expanded = btn.getAttribute('aria-expanded') === 'true';
			btn.setAttribute('aria-expanded', String(!expanded));
			menu.classList.toggle('open', !expanded);
			closeQrOverlay();
		});

		document.addEventListener('click', () => {
			btn.setAttribute('aria-expanded', 'false');
			menu.classList.remove('open');
			closeQrOverlay();
		});

		if (qrOverlay) {
			qrOverlay.querySelector('.share-qr-close')?.addEventListener('click', (e) => {
				e.stopPropagation();
				closeQrOverlay();
			});
			qrOverlay.querySelector('.share-qr-backdrop')?.addEventListener('click', () => {
				closeQrOverlay();
			});
		}

		options?.forEach((opt) => {
			opt.addEventListener('click', async (e) => {
				const action = opt.getAttribute('data-action');
				if (action === 'qr') {
					e.stopPropagation();
					if (qrOverlay) {
						qrOverlay.hidden = !qrOverlay.hidden;
						menu.classList.remove('open');
						btn.setAttribute('aria-expanded', 'false');
					}
					return;
				}
				if (action === 'share') {
					if (navigator.share) {
						try {
							await navigator.share({
								title: document.title,
								url: fullUrl,
							});
						} catch (err) {
							if ((err).name !== 'AbortError') {
								await copyToClipboard(fullUrl);
							}
						}
					} else {
						await copyToClipboard(fullUrl);
					}
					menu.classList.remove('open');
					btn.setAttribute('aria-expanded', 'false');
				} else if (action === 'copy') {
					await copyToClipboard(fullUrl);
					menu.classList.remove('open');
					btn.setAttribute('aria-expanded', 'false');
				}
			});
		});

		async function copyToClipboard(text) {
			try {
				await navigator.clipboard.writeText(text);
			} catch {
				const ta = document.createElement('textarea');
				ta.value = text;
				ta.style.position = 'fixed';
				ta.style.opacity = '0';
				document.body.appendChild(ta);
				ta.select();
				document.execCommand('copy');
				document.body.removeChild(ta);
			}
		}
	});
</script>

<style>
	.share-button {
		position: fixed;
		bottom: 1.5rem;
		left: 1.5rem;
		z-index: 100;
	}

	.share-btn {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 1rem;
		background: var(--surface);
		color: var(--text);
		border: 1px solid var(--border);
		border-radius: 8px;
		box-shadow: var(--shadow);
		cursor: pointer;
		font-family: inherit;
		font-size: 0.9rem;
		transition: box-shadow 0.2s;
	}
	.share-btn:hover {
		box-shadow: var(--shadow-hover);
	}

	.share-menu {
		position: absolute;
		bottom: 100%;
		left: 0;
		margin-bottom: 0.5rem;
		min-width: 140px;
		padding: 0.25rem;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 8px;
		box-shadow: var(--shadow-hover);
		opacity: 0;
		visibility: hidden;
		transition: opacity 0.2s, visibility 0.2s;
	}
	.share-menu.open {
		opacity: 1;
		visibility: visible;
	}

	.share-option {
		display: block;
		width: 100%;
		padding: 0.5rem 0.75rem;
		border: none;
		border-radius: 6px;
		background: transparent;
		color: var(--text);
		font-size: 0.9rem;
		text-align: left;
		cursor: pointer;
		transition: background 0.15s;
	}
	.share-option:hover {
		background: var(--primary-soft);
		color: var(--primary);
	}

	.share-qr-overlay {
		position: fixed;
		inset: 0;
		z-index: 1000;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 2rem;
	}
	.share-qr-overlay[hidden] {
		display: none;
	}
	.share-qr-backdrop {
		position: absolute;
		inset: 0;
		background: rgba(0, 0, 0, 0.75);
		cursor: pointer;
	}
	.share-qr-content {
		position: relative;
		z-index: 1;
		background: var(--surface);
		border-radius: 8px;
		padding: 2rem;
		padding-top: 2.5rem;
		box-shadow: var(--shadow-hover);
		width: min(90vmin, 512px);
		height: min(90vmin, 512px);
	}
	.share-qr-content img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: contain;
	}
	.share-qr-close {
		position: absolute;
		top: 0.5rem;
		right: 0.5rem;
		z-index: 3;
		width: 2rem;
		height: 2rem;
		border: none;
		border-radius: 6px;
		background: var(--surface);
		color: var(--text);
		font-size: 1.5rem;
		line-height: 1;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.share-qr-close:hover {
		background: var(--primary-soft);
		color: var(--primary);
	}
</style>
