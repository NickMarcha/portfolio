---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
		</div>
		<div class="github-dropdown">
			<a href="https://github.com/NickMarcha" target="_blank" rel="noopener noreferrer" class="github-btn">
				<span class="sr-only">NickMarcha on GitHub</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32">
					<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
				</svg>
			</a>
			<div class="github-dropdown-menu">
				<a href="https://github.com/NickMarcha" target="_blank" rel="noopener noreferrer">github.com/NickMarcha</a>
				<a href="https://github.com/NickMarcha/portfolio" target="_blank" rel="noopener noreferrer">repository for this site</a>
			</div>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--surface);
		box-shadow: 0 2px 8px oklch(0.28 0.03 194.79 / 0.06);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--text);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--primary);
	}
	.github-dropdown {
		position: relative;
		align-self: center;
	}
	.github-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.5em;
		background: var(--primary-soft);
		border: 1px solid oklch(0.5 0.03 194.79 / 0.25);
		border-radius: 6px;
		transition: background 0.2s, border-color 0.2s;
	}
	.github-btn svg {
		display: block;
	}
	.github-btn:hover {
		background: var(--primary-pastel);
		border-color: oklch(0.5 0.03 194.79 / 0.4);
	}
	.github-dropdown-menu {
		position: absolute;
		top: 100%;
		right: 0;
		margin-top: 0.25em;
		min-width: 200px;
		background: var(--surface);
		border-radius: 6px;
		box-shadow: var(--shadow-hover);
		border: 1px solid var(--border);
		opacity: 0;
		visibility: hidden;
		transform: translateY(-4px);
		transition: opacity 0.2s, visibility 0.2s, transform 0.2s;
		z-index: 10;
	}
	.github-dropdown:hover .github-dropdown-menu {
		opacity: 1;
		visibility: visible;
		transform: translateY(0);
	}
	.github-dropdown-menu a {
		display: block;
		padding: 0.6em 1em;
		white-space: nowrap;
		border-bottom: 1px solid var(--border);
	}
	.github-dropdown-menu a:last-child {
		border-bottom: none;
	}
	.github-dropdown-menu a:hover {
		background: var(--primary-soft);
	}
	@media (max-width: 720px) {
		.github-dropdown {
			display: none;
		}
	}
</style>
