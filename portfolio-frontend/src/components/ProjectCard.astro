---
import { TagList } from './TagList';
import type { Locale } from '../i18n';

interface Props {
	title: string;
	description: string;
	image: string;
	href: string;
	slug?: string;
	pixelArt?: boolean;
	tags?: string[];
	lang?: Locale;
}

const { title, description, image, href, slug, pixelArt = false, tags = [], lang = 'en' } = Astro.props;
---

<a href={href} class="project-card" data-project-slug={slug}>
	<img src={image} alt={title} loading="lazy" class:list={[{ 'pixel-art': pixelArt }]} />
	<div class="card-content">
		<h3>{title}</h3>
		<p>{description}</p>
		{tags.length > 0 && <TagList tags={tags} lang={lang} client:load />}
	</div>
</a>

<style>
	.project-card {
		display: block;
		text-decoration: none;
		color: inherit;
		background: var(--surface);
		border-radius: 8px;
		overflow: hidden;
		box-shadow: var(--shadow);
		transition: box-shadow 0.2s;
	}
	.project-card:hover {
		box-shadow: var(--shadow-hover);
	}
	.project-card img {
		width: 100%;
		height: 180px;
		object-fit: cover;
		display: block;
	}
	.project-card img.pixel-art {
		image-rendering: pixelated;
	}
	.card-content {
		padding: 1em 1.25em;
	}
	.card-content h3 {
		margin: 0 0 0.25em 0;
		font-size: 1.25em;
	}
	.card-content p {
		margin: 0;
		font-size: 0.9em;
		color: var(--text-muted);
	}
	/* NOT expanded: single line; expanded: wrap to multiple lines */
	.project-card :global(.tag-list-wrapper) {
		display: flex;
		align-items: center;
		gap: 0.35em;
		margin: 0.5em 0 0 0;
		min-width: 0;
	}
	.project-card :global(.tag-list-wrapper:not([data-expanded="true"])) {
		flex-wrap: nowrap;
		overflow-x: auto;
		overflow-y: hidden;
		scrollbar-width: none;
		-webkit-overflow-scrolling: touch;
	}
	.project-card :global(.tag-list-wrapper:not([data-expanded="true"])::-webkit-scrollbar) {
		display: none;
	}
	.project-card :global(.tag-list-wrapper[data-expanded="true"]) {
		flex-wrap: wrap;
	}
	.project-card :global(.tag-list) {
		display: flex;
		gap: 0.35em;
		margin: 0;
		padding: 0;
		list-style: none;
	}
	.project-card :global(.tag-list-wrapper:not([data-expanded="true"]) .tag-list) {
		flex-wrap: nowrap;
		flex: 1 1 0;
		min-width: 0;
	}
	.project-card :global(.tag-list-wrapper[data-expanded="true"] .tag-list) {
		flex-wrap: wrap;
	}
	.project-card :global(.tag-list li) {
		flex-shrink: 0;
	}
	.project-card :global(.tag) {
		font-size: 0.75em;
		padding: 0.2em 0.5em;
		border-radius: 4px;
		border: 1px solid var(--border);
		background: var(--muted);
		color: var(--primary);
		cursor: pointer;
		transition: box-shadow 0.15s, color 0.15s;
	}
	.project-card :global(.tag:hover) {
		color: var(--primary-dark);
		box-shadow: var(--shadow);
	}
	.project-card :global(.tag-more) {
		flex-shrink: 0;
		color: var(--text-muted);
		font-style: italic;
	}
</style>
