---
interface Props {
	title: string;
	description: string;
	image: string;
	slug: string;
	pixelArt?: boolean;
}

const { title, description, image, slug, pixelArt = false } = Astro.props;
---

<a href={`/projects/${slug}`} class="project-card">
	<img src={image} alt={title} loading="lazy" class:list={[{ 'pixel-art': pixelArt }]} />
	<div class="card-content">
		<h3>{title}</h3>
		<p>{description}</p>
	</div>
</a>

<style>
	.project-card {
		display: block;
		text-decoration: none;
		color: inherit;
		background: var(--surface);
		border-radius: 8px;
		overflow: hidden;
		box-shadow: var(--shadow);
		transition: box-shadow 0.2s;
	}
	.project-card:hover {
		box-shadow: var(--shadow-hover);
	}
	.project-card img {
		width: 100%;
		height: 180px;
		object-fit: cover;
		display: block;
	}
	.project-card img.pixel-art {
		image-rendering: pixelated;
	}
	.card-content {
		padding: 1em 1.25em;
	}
	.card-content h3 {
		margin: 0 0 0.25em 0;
		font-size: 1.25em;
	}
	.card-content p {
		margin: 0;
		font-size: 0.9em;
		color: var(--text-muted);
	}
</style>
