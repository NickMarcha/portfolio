---
import type { IProjectData } from '../../data/projectData';
import type { Locale } from '../../i18n';
import Bio from './projects/Bio.astro';
import InkyPen from './projects/InkyPen.astro';
import KriskogramImage from '../assets/Kriskogram.png';
import RaffleDashboard from './projects/RaffleDashboard.astro';
import BachelorsProject from './projects/BachelorsProject.astro';
import GameJams from './projects/GameJams.astro';
import BadlandsRP from './projects/BadlandsRP.astro';
import SchoolAssignments from './projects/SchoolAssignments.astro';
import Kriskogram from './projects/Kriskogram.astro';
import { ProjectImageCarousel } from './ProjectImageCarousel';
import { ZoomableImage } from './ZoomableImage';

interface CarouselItemWithCaption {
	type: 'image' | 'youtube' | 'video';
	src?: string;
	videoId?: string;
	caption?: string;
}

interface Props {
	project: IProjectData;
	slug: string;
	lang: Locale;
	longTitle: string;
	carouselItems: CarouselItemWithCaption[];
	body?: string;
}

const { project, slug, lang, longTitle, carouselItems, body } = Astro.props;
const components: Record<string, typeof Bio> = {
	Bio,
	InkyPen,
	RaffleDashboard,
	BachelorsProject,
	GameJams,
	BadlandsRP,
	SchoolAssignments,
	Kriskogram,
};
const DescriptionComponent = components[project.long.descriptionComponent];
---

<article class="project-detail">
	{project.slug === 'kriskogram' && (
		<ZoomableImage
			src={KriskogramImage.src}
			alt=""
			className="project-header-image"
			imgClassName="w-full h-full object-cover block"
			client:load
		/>
	)}
	<h1 data-i18n-long-title={slug}>{longTitle}</h1>
	{carouselItems.length > 0 && (
		<div class="project-images">
			<ProjectImageCarousel items={carouselItems} projectSlug={slug} client:load />
		</div>
	)}
	<div class="project-description" data-i18n-body={slug}>
		{body ? (
			<div set:html={body} />
		) : (
			DescriptionComponent && <DescriptionComponent lang={lang} />
		)}
	</div>
</article>

<style>
	.project-detail {
		margin-bottom: 2em;
	}
	.project-header-image {
		width: 100%;
		max-height: 280px;
		overflow: hidden;
		border-radius: 8px;
		margin-bottom: 1.5em;
	}
	.project-header-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.project-images {
		margin: 1.5em 0;
	}
	.project-description {
		margin-top: 1.5em;
	}
	/* Styles for body-rendered content (e.g. InkyPen bankruptcy notice) */
	.project-description :global(.bankruptcy-notice) {
		padding: 1rem 1.25rem;
		margin-bottom: 1.5rem;
		background: rgba(234, 179, 8, 0.12);
		border-left: 4px solid rgb(202, 138, 4);
		border-radius: 0 6px 6px 0;
		font-size: 0.95em;
	}
	.project-description :global(.bankruptcy-notice a) {
		color: var(--primary);
	}
</style>
