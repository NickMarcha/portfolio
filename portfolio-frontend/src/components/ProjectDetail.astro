---
import type { IProjectData } from '../../data/projectData';
import Bio from './projects/Bio.astro';
import InkyPen from './projects/InkyPen.astro';
import KriskogramImage from '../assets/Kriskogram.png';
import RaffleDashboard from './projects/RaffleDashboard.astro';
import BachelorsProject from './projects/BachelorsProject.astro';
import GameJams from './projects/GameJams.astro';
import BadlandsRP from './projects/BadlandsRP.astro';
import SchoolAssignments from './projects/SchoolAssignments.astro';
import Kriskogram from './projects/Kriskogram.astro';

interface Props {
	project: IProjectData;
	slug: string;
}

const { project, slug } = Astro.props;
const components: Record<string, typeof Bio> = {
	Bio,
	InkyPen,
	RaffleDashboard,
	BachelorsProject,
	GameJams,
	BadlandsRP,
	SchoolAssignments,
	Kriskogram,
};
const DescriptionComponent = components[project.long.descriptionComponent];
---

<article class="project-detail">
	{project.slug === 'kriskogram' && (
		<div class="project-header-image">
			<img src={KriskogramImage.src} alt="" />
		</div>
	)}
	<h1>{project.long.title}</h1>
	{project.long.images.length > 0 && (
		<div class="project-images">
			{project.long.images.map((src) => (
				<img src={src} alt="" loading="lazy" />
			))}
		</div>
	)}
	<div class="project-description">
		{DescriptionComponent && <DescriptionComponent />}
	</div>
</article>

<style>
	.project-detail {
		margin-bottom: 2em;
	}
	.project-header-image {
		width: 100%;
		max-height: 280px;
		overflow: hidden;
		border-radius: 8px;
		margin-bottom: 1.5em;
	}
	.project-header-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.project-images {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 1em;
		margin: 1.5em 0;
	}
	.project-images img {
		width: 100%;
		height: auto;
		border-radius: 8px;
	}
	.project-description {
		margin-top: 1.5em;
	}
</style>
