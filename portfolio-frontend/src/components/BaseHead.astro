---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import { SITE_TITLE } from '../consts';
import iconMe from '../assets/images/icon-me.png';

const DEFAULT_OG_IMAGE = { src: '/og-image.png' };

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata | { src: string };
	lang?: string;
}

const url = Astro.url;
const canonicalURL = new URL(url.pathname + (url.search || ''), Astro.site);

const { title, description, image = DEFAULT_OG_IMAGE, lang = 'en' } = Astro.props;
const imageSrc = image.src;
const isDefaultOgImage = imageSrc === '/og-image.png';
---

<!-- Theme: apply stored preference before paint to avoid flash -->
<script is:inline>
	(function() {
		try {
			var theme = localStorage.getItem('portfolio-theme');
			if (theme === 'light' || theme === 'dark' || theme === 'system') {
				document.documentElement.setAttribute('data-theme', theme);
			}
		} catch (e) {}
	})();
</script>
<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/png" href={iconMe.src} />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Font preloads -->
<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(imageSrc, Astro.url)} />
{isDefaultOgImage && (
	<>
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
	</>
)}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(imageSrc, Astro.url)} />

<script>
	(function initSideButtonsIdle() {
		const IDLE_MS = 3000;
		const MOBILE = '(max-width: 720px)';
		let timer: number | null = null;

		const IGNORE_FIRST_MS = 150;

		function show() {
			const wasHidden = document.body.hasAttribute('data-side-buttons-hidden');
			document.body.removeAttribute('data-side-buttons-hidden');
			if (wasHidden) {
				document.body.setAttribute('data-side-buttons-ignore-first', '');
				setTimeout(() => document.body.removeAttribute('data-side-buttons-ignore-first'), IGNORE_FIRST_MS);
			}
			if (timer) clearTimeout(timer);
			if (!window.matchMedia(MOBILE).matches) return;
			timer = setTimeout(hide, IDLE_MS);
		}

		function hide() {
			if (!window.matchMedia(MOBILE).matches) return;
			const menuOpen = document.querySelector('[aria-expanded="true"]');
			if (menuOpen) return;
			document.body.setAttribute('data-side-buttons-hidden', '');
			timer = null;
		}

		function setup() {
			if (!window.matchMedia(MOBILE).matches) return;
			timer = setTimeout(hide, IDLE_MS);
			window.addEventListener('scroll', show, { passive: true });
			window.addEventListener('touchstart', show, { passive: true });
			window.addEventListener('wheel', show, { passive: true });
			window.addEventListener('resize', () => {
				if (!window.matchMedia(MOBILE).matches) {
					document.body.removeAttribute('data-side-buttons-hidden');
					if (timer) clearTimeout(timer);
					timer = null;
				}
			});
		}

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', setup);
		} else {
			setup();
		}
	})();
</script>
<script>
	(async () => {
		const isLocal =
			typeof window !== 'undefined' &&
			(window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1');
		const apiUrl = isLocal ? 'http://localhost:3000' : 'https://api-portfolio.nickmarcha.com';
		try {
			const res = await fetch(`${apiUrl}/`);
			const data = (await res.json()) as { message?: string; version?: string };
			if (res.ok) {
				console.log('[Portfolio] Backend connected. Version:', data.version ?? 'unknown');
			} else {
				console.warn('[Portfolio] Backend returned', res.status, data);
			}
		} catch (err) {
			console.warn('[Portfolio] Backend unreachable:', err instanceof Error ? err.message : err);
		}
		fetch(`${apiUrl}/api/visits`, {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify({ path: window.location.pathname }),
		}).catch(() => {});
	})();
</script>
